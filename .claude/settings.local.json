{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)"
    ],
    "additionalDirectories": [
      "/private/tmp",
      "/tmp"
    ],
    "defaultMode": "acceptEdits"
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "*.npmjs.org",
        "*.yarnpkg.com",
        "*.github.com",
        "github.com",
        "*.githubusercontent.com",
        "*.figma.com",
        "*.decodebackoffice.com",
        "*.dev.decodebackoffice.com",
        "api.dev.decodebackoffice.com"
      ]
    }
  }
}
